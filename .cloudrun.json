{
  "steps": [
    {
      "name": "gcr.io/cloud-builders/docker",
      "args": [
        "build",
        "-t",
        "gcr.io/$PROJECT_ID/optics-master:$SHORT_SHA",
        "-t",
        "gcr.io/$PROJECT_ID/optics-master:latest",
        "."
      ]
    },
    {
      "name": "gcr.io/cloud-builders/docker",
      "args": [
        "push",
        "gcr.io/$PROJECT_ID/optics-master"
      ]
    },
    {
      "name": "gcr.io/cloud-builders/run",
      "args": [
        "deploy",
        "optics-master",
        "--image",
        "gcr.io/$PROJECT_ID/optics-master:$SHORT_SHA",
        "--region",
        "us-central1",
        "--platform",
        "managed",
        "--allow-unauthenticated"
      ]
    }
  ],
  "images": [
    "gcr.io/$PROJECT_ID/optics-master:$SHORT_SHA",
    "gcr.io/$PROJECT_ID/optics-master:latest"
  ],
  "timeout": "1800s"
}
