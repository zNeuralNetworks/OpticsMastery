{
  "name": "optics-master",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <24",
    "npm": ">=10.9.2 <11"
  },
  "scripts": {
    "doctor": "node ./scripts/doctor.mjs",
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "verify": "npm run doctor && npm run typecheck && npm run test:ci && npm run build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.15.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.6",
    "vitest": "^3.2.4"
  }
}
